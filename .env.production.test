# Copy to .env.production and fill in before deploying.
# Generate APP_KEY: cd backend && php artisan key:generate --show

APP_KEY=
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true

POSTGRES_DB=purrfect_match
POSTGRES_USER=purrfect
POSTGRES_PASSWORD=change-me-strong-password

NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_REVERB_HOST=ws.yourdomain.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https

REVERB_APP_ID=purrfect
REVERB_APP_KEY=change-me-reverb-key
REVERB_APP_SECRET=change-me-reverb-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

AUTO_SEED=true

BACKEND_PORT=8000
FRONTEND_PORT=3000

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
